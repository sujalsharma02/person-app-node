<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Person</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="container fade-in">
        <header class="header">
            <h1>Create New Person</h1>
            <a href="/person" class="btn btn-outline">&larr; Back to Directory</a>
        </header>

        <div class="card form-card">
            <form action="/person" method="POST" class="form">
                <div class="form-group">
                    <label for="Name">Name</label>
                    <input type="text" id="Name" name="Name" required placeholder="John Doe">
                </div>

                <div class="form-group">
                    <label for="Age">Age</label>
                    <input type="number" id="Age" name="Age" required min="1" max="150" placeholder="30">
                </div>

                <div class="form-group">
                    <label for="Gender">Gender</label>
                    <select id="Gender" name="Gender" required>
                        <option value="" disabled selected>Select Gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="Mobile">Mobile Number</label>
                    <input type="tel" id="Mobile" name="Mobile number" required placeholder="+1 123-456-7890">
                </div>

                <button type="submit" class="btn btn-primary btn-block">Create Person</button>
            </form>
        </div>
    </div>
</body>

</html>